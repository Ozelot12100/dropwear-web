# Variables de entorno del frontend (Vite). Copia este archivo a `.env.local`
# y pide los valores reales al administrador de la organización en Supabase.
# NOTA: ambas son PÚBLICAS por diseño (viajan en el bundle); la seguridad la
# aporta el Row Level Security de la base de datos, no el secreto de estas claves.

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
